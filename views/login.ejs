<!DOCTYPE html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta http-equiv="X-UA-Compatible" content="IE=edge" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>Library Management System</title>
		<link rel="stylesheet" href="style.css" />
	</head>
	<body>
		<header>
			<div class="logo">
				<img width='50' height='50' src="img/logo.png">
				<a href="/"><h1>Library </h1></a>
				
			</div>
			<nav>
				<ul>
					<li><a href="books">Books</a></li>
					<% if(user) { %>

					<li>
						<div class="dropdown">
							<button class="dropbtn">Hello <%= user.name%></button>
							<div class="dropdown-content">
								<a href="me">Account</a>
								<a class="logout">Logout</a>
							</div>
						</div>
					</li>
					<% }else{ %>
					<li><a href="login">Login</a></li>
					<li><a href="signup">SignUp</a></li>
					<% } %>
				</ul>
			</nav>
		</header>
		
		<div class="login-body">
            <h1 class="login-title">Login</h1>
			<div class="login-form form">
				<form class="login">
					<div class="login">
						<input type="text" id="email" placeholder="Enter Email" required />
						<input
							type="text"
							id="password"
							placeholder="Enter Password"
							required
						/>
                        <div class="forgotpassword">Forget password?</div>
						<button class="login-btn">Login</button>

					</div>
				</form>
                <p class="login-info">Doesn't have an Account?<a href="signup">SignUp</a></p>
			</div>
		</div>
		<script src="https://cdnjs.cloudflare.com/ajax/libs/axios/0.26.1/axios.min.js"></script>
		<script src="js/index.js"></script>
	</body>
</html>
