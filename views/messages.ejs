<!DOCTYPE html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta http-equiv="X-UA-Compatible" content="IE=edge" />



		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>Library Management System</title>
		<link rel="stylesheet" href="style.css" />
	</head>
	<body>
		<header>
			<div class="logo">
				<img width='50' height='50' src="img/logo.png">
				<a href="/"><h1>Library</h1></a>
			</div>
			<nav>
				<ul>
					<li><a href="books">Books</a></li>
					<% if(user) { %>
						
						<% if(user.role==='user'){ %>
							<li><a href="/cart">Cart(<%=user.cart.length %>)</a></li>
							<% } %>
							
					<li>
						<div class="dropdown">
							<button class="dropbtn">Hello, <span class="name"><%= user.name%></span></button>
							<div class="dropdown-content">
								<a href="me">Account</a>
								<% if(user.role==='user'){ %>
									<a href="/messages">Messages</a>
									<% } %>
								<a class="logout">Logout</a>
							</div>
						</div>
					</li>
					<% }else{ %>
					<li><a href="login">Login</a></li>
					<li><a href="signup">SignUp</a></li>
					<% } %>
				</ul>
			</nav>
		</header>

<% books.forEach(book=>{ %>
<h1>  <a href=book/<%= book.slug %>><%= book.name %> Available Now </a></h1>
<button class="removeinterestbtn"  data-bookId=<%= book._id %>>Ok</button>

	<% }) %>




		<script src="https://cdnjs.cloudflare.com/ajax/libs/axios/0.26.1/axios.min.js"></script>
		<script src="/js/index.js"></script>
	</body>
</html>
