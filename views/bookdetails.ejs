<!DOCTYPE html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta http-equiv="X-UA-Compatible" content="IE=edge" />



		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>Library Management System</title>
		<link rel="stylesheet" href="style.css" />
	</head>
	<body>
		<header>
			<div class="logo">
				<img width='50' height='50' src="img/logo.png">
				<a href="/"><h1>Library</h1></a>
			</div>
			<nav>
				<ul>
					<li><a href="books">Books</a></li>
					<% if(user) { %>
						
					<li>
						<div class="dropdown">
							<button class="dropbtn">Hello, <span class="name"><%= user.name%></span></button>
							<div class="dropdown-content">
								<a href="me">Account</a>
								
								<a class="logout">Logout</a>
							</div>
						</div>
					</li>
					<% }else{ %>
					<li><a href="login">Login</a></li>
					<li><a href="signup">SignUp</a></li>
					<% } %>
				</ul>
			</nav>
		</header>

<div class="booktable">

<table>
    <th>
        <td>S.no</td>
        <td>Book Image</td>
        <td>Book name</td>
        <td>NO of books</td>
        <td>NO of users taken</td>
    </th>
<% books.forEach((book,index)=>{  %>

<tr>
    <td><%= index+1 %></td>
    <td><img width='100' height='100' src=<%=book.image %></td>
    <td><%= book.name %></td>
    <td><%= book.NoofBooks %></td>
    <td><%= book.issued %> </td>
</tr>
<% }) %>


</table>

</div>



		<script src="https://cdnjs.cloudflare.com/ajax/libs/axios/0.26.1/axios.min.js"></script>
		<script src="/js/index.js"></script>
	</body>
</html>
