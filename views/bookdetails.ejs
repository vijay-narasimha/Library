<%- include('header') %>

<div class="booktable">

<table>
    <th>
        <td>S.no</td>
        <td>Book Image</td>
        <td>Book name</td>
        <td>NO of books</td>
        <td>NO of users taken</td>
    </th>
<% books.forEach((book,index)=>{  %>

<tr>
    <td><%= index+1 %></td>
    <td><img width='100' height='100' src=<%=book.image %></td>
    <td><%= book.name %></td>
    <td><%= book.NoofBooks %></td>
    <td><%= book.issued %> </td>
</tr>
<% }) %>


</table>

</div>



<%- include('footer') %>