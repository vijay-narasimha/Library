<!DOCTYPE html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta http-equiv="X-UA-Compatible" content="IE=edge" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>Library Management System</title>
		<link rel="stylesheet" href="/style.css" />
	</head>
	<body>
		<header>
			<div class="logo">
				<img width="50" height="50" src="/img/logo.png" />
				<a href="/"><h1>Library</h1></a>
			</div>
			<nav>
				<ul>
					<li><a href="/books">Books</a></li>
					<% if(user) { %>
						
						<% if(user.role==='user'){ %>
							<li><a href="/cart">Cart(<%=user.cart.length %>)</a></li>
							<% } %>
					
					<li>
						
						<div class="dropdown">
							<button class="dropbtn">Hello <%= user.name%></button>
							<div class="dropdown-content">
								<a href="me">Account</a>
								<% if(user.role==='user'){ %>
									<a href="/messages">Messages</a>
									<% } %>
								<a class="logout">Logout</a>
							</div>
						</div>
					</li>
					<% }else{ %>
					<li><a href="/login">Login</a></li>
					<li><a href="/signup">SignUp</a></li>
					<% } %>
				</ul>
			</nav>
		</header>

		<div class="bookdetails">
			<div class="bookimage">
				<img width="350" height="500" src=<%= book.image %>>
			</div>

			<div class="bookinformation">
				<p class="booktitle"><%= book.name%></p>
				<div class="bookauthor">
					<h2>by,<span><%= book.author%></span></h2>
				</div>

				
				<div>
					<h2>Description:</h2>
					<p class="bookdescription"><%= book.description%></p>
				</div>
			
	
			</div>
			
		</div>

		<script src="https://cdnjs.cloudflare.com/ajax/libs/axios/0.26.1/axios.min.js"></script>
		<script src="/js/index.js"></script>
	</body>
</html>
