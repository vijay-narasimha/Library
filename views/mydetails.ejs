<!DOCTYPE html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta http-equiv="X-UA-Compatible" content="IE=edge" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<title>Library Management System</title>
		<link rel="stylesheet" href="style.css" />
	</head>
	<body>
		<header>
			<div class="logo">
				<img width='50' height='50' src="img/logo.png">
				<a href="/"><h1>Library</h1></a>
			</div>
			<nav>
				<ul>
					<li><a href="books">Books</a></li>
					<% if(user) { %>
						
						<% if(user.role==='user'){ %>
							<li><a href="/cart">Cart(<%=user.cart.length %>)</a></li>
							<% } %>
							
					<li>
						<div class="dropdown">
							<button class="dropbtn">Hello <%= user.name%></button>
							<div class="dropdown-content">
								<a href="me">Account</a>
								<% if(user.role==='user'){ %>
									<a href="/messages">Messages</a>
									<% } %>
								<a class="logout">Logout</a>
							</div>
						</div>
					</li>
					<% }else{ %>
					<li><a href="login">Login</a></li>
					<li><a href="signup">SignUp</a></li>
					<% } %>
				</ul>
			</nav>
		</header>

<div class="my-details">
    <div class="reference">
        <ul>
            <li><a href="/issuedbooks">Issued Books</a></li>
            <li><a href="/savedbooks">Returned Books</a></li>
            <li ><a href="/interestedbooks">Interested Books</a></li>
          

        </ul>
    </div>
    <div class="update-details">
        <div class="personal-update">
            <h2 class="update-title">Personal Details</h2>
            <form  class="update-form">
                <input type="text" value=<%= user.name %> >
                <input type="text" value=<%= user.email %> > <input type="text" value=<%= user.phonenumber %> >
                <button  class="update-btn" type="submit">Update</button>
            </form>
			<h2>Pass Available:</h2>
			<h3><%= user.passAvailable %></h3>
        </div>
        <div class="password-update">
            <h2 class="update-title">Reset Password</h2>
            <form class="update-form">
                <input type="password" placeholder="Enter password" required>
                <input type="password" placeholder="Enter confirm Password" required>
                <button class="update-btn" type="submit">Reset</button>

            </form>
        </div>
    </div>
</div>


		<script src="https://cdnjs.cloudflare.com/ajax/libs/axios/0.26.1/axios.min.js"></script>
		<script src="js/index.js"></script>
	</body>
</html>
